# Odoo connection
ODOO_URL=https://odoo.example.com
ODOO_DB=mydb
ODOO_LOGIN=bot@example.com
ODOO_PASSWORD=secret

# OpenClaw gateway (local)
OPENCLAW_HOOKS_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOKS_TOKEN=your-hook-token

# Bridge settings
RECONNECT_DELAY=5
POLL_INTERVAL=15
LOG_LEVEL=INFO
